configuration {
    modi:                "drun,run,window";
    show-icons:          true;
    icon-theme:          "Papirus-Dark";
    display-drun:        " Apps";
    display-run:         " Run";
    display-window:      " Window";
    drun-display-format: "{name}";
    font:                "JetBrainsMono Nerd Font 11";
    terminal:            "kitty";
}

@import "theme.rasi"
